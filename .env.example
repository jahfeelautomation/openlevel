DATABASE_URL=postgres://openlevel:openlevel@localhost:5432/openlevel
SESSION_SECRET=dev-only-change-me
CHATWOOT_WEBHOOK_SECRET=dev-secret
CHATWOOT_BASE_URL=https://chat.jahfeelautomation.com
PORT=8790

# Per-client Anthropic key (D-44/D-36). The operator assistant and the customer
# agent resolve the secret name "<client_slug>:anthropic:api_key", which maps to
# the env var <SLUG>_ANTHROPIC_API_KEY (uppercased, every non-alphanumeric -> _).
# One per client; the agent never sees the raw value, only resolveSecret() does.
ADMIN_ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ACME_ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
